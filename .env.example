# Kimodo Environment Configuration
# Copy to .env and fill in your values

# Required: HuggingFace token (must have access to meta-llama/Meta-Llama-3-8B-Instruct)
# Get it at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Optional: Device for text encoder (cuda or cpu)
# Use "cpu" if you have <16GB VRAM
TEXT_ENCODER_DEVICE=cuda

# Optional: Server port for demo
SERVER_PORT=7860

# Optional: Text encoder service URL (for CLI usage with separate encoder)
TEXT_ENCODER_URL=http://localhost:9550/
